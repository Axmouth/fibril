---
import StatusBadge from "./StatusBadge.astro";

const features = [
  {
    feature: "Durable queues",
    status: { kind: "ready", label: "available" },
    notes: "Append-only log, snapshot, and replay.",
  },
  {
    feature: "Publish and subscribe",
    status: { kind: "ready", label: "available" },
    notes: "Custom TCP protocol with Rust, TypeScript, and Python clients.",
  },
  {
    feature: "Explicit settlement",
    status: { kind: "ready", label: "available" },
    notes: "ACK, fail, immediate retry, and delayed retry paths.",
  },
  {
    feature: "Delayed publish",
    status: { kind: "ready", label: "available" },
    notes: "Broker path and Rust, TypeScript, and Python client methods are wired.",
  },
  {
    feature: "Message TTL",
    status: { kind: "ready", label: "available" },
    notes: "Per-message or per-queue default. Expired messages drop or dead-letter.",
  },
  {
    feature: "Dead lettering",
    status: { kind: "ready", label: "available" },
    notes: "Global and per-queue policy are configurable. Replay tooling is still early.",
  },
  {
    feature: "Backpressure",
    status: { kind: "ready", label: "available" },
    notes: "Pull-based delivery and bounded prefetch.",
  },
  {
    feature: "Sparse queues",
    status: { kind: "ready", label: "available" },
    notes: "Lazy loading and idle eviction are wired. Observability is still growing.",
  },
  {
    feature: "Message inspection",
    status: { kind: "ready", label: "available" },
    notes: "Browse active queue messages from admin tooling, with optional payload previews.",
  },
  {
    feature: "Partitioned queues",
    status: { kind: "ready", label: "available" },
    notes: "Multiple partitions per queue, with client-side key routing and transparent fan-in.",
  },
  {
    feature: "Plexus streams",
    status: { kind: "ready", label: "available" },
    notes: "Fan-out channel: every subscriber receives every record, with durable named cursors and durability tiers you opt into.",
  },
  {
    feature: "Partition ownership",
    status: { kind: "partial", label: "experimental" },
    notes: "Cluster nodes split a queue's active traffic by owning different partitions. Experimental.",
  },
  {
    feature: "Replication",
    status: { kind: "partial", label: "experimental" },
    notes: "Followers keep partition copies for failover and recovery. Experimental.",
  },
  {
    feature: "Transactions",
    status: { kind: "no", label: "out of scope" },
    notes: "Not planned. Transactional workflows are intentionally excluded.",
  },
] as const;
---

<div class="matrix-wrap" aria-label="Feature status matrix">
  <table class="matrix desktop-matrix">
    <thead>
      <tr><th>Feature</th><th>Status</th><th>Notes</th></tr>
    </thead>
    <tbody>
      {features.map((item) => (
        <tr>
          <td>{item.feature}</td>
          <td><StatusBadge kind={item.status.kind}>{item.status.label}</StatusBadge></td>
          <td>{item.notes}</td>
        </tr>
      ))}
    </tbody>
  </table>

  <div class="mobile-matrix">
    {features.map((item) => (
      <article class="matrix-card">
        <div>
          <h3>{item.feature}</h3>
          <StatusBadge kind={item.status.kind}>{item.status.label}</StatusBadge>
        </div>
        <p>{item.notes}</p>
      </article>
    ))}
  </div>
</div>
